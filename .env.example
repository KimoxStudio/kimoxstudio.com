# Contact form delivery (Resend) — required in production
# Sign up: https://resend.com  (free tier: 100 emails/day, 3 000/month)
# 1. Verify your domain in the Resend dashboard (DNS records on Vercel).
# 2. Create an API key with Sending Access.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# From address. Must use a domain you've verified in Resend. For quick
# testing you can keep "onboarding@resend.dev" (default if not set).
RESEND_FROM="Kimox Studio <hola@kimoxstudio.com>"
# Where contact messages land.
RESEND_TO=kimoxstudio@gmail.com

# Rate limiting (Upstash Redis) — optional in dev, required in production
# Sign up: https://upstash.com  (free tier: 10 000 commands/day)
# Create a Redis database, then copy the REST URL + token.
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=AY...your_token...
